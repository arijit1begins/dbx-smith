#!/usr/bin/env bash
# dbx-smith-spin - The CLI Factory / Provisioner
# Refactored for modularity, factory patterns, and dependency injection.

set -euo pipefail

# --- [ Dependency Injection & Module Loading ] ---
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dbx-smith"
SRC_DIR="$CONFIG_DIR/src"

# Developer override: if running from a local clone, prioritize the local src/
REPO_SRC="$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")/src"
if [[ -d "$REPO_SRC" ]]; then
    SRC_DIR="$REPO_SRC"
fi
readonly SRC_DIR

# shellcheck source=src/core/constants.sh
# shellcheck disable=SC1091
source "${SRC_DIR}/core/constants.sh"
# shellcheck source=src/core/utils.sh
# shellcheck disable=SC1091
source "${SRC_DIR}/core/utils.sh"
# shellcheck source=src/core/payload.sh
# shellcheck disable=SC1091
source "${SRC_DIR}/core/payload.sh"
# shellcheck source=src/core/distro_factory.sh
# shellcheck disable=SC1091
source "${SRC_DIR}/core/distro_factory.sh"
# shellcheck source=src/strategies/factory.sh
# shellcheck disable=SC1091
source "${SRC_DIR}/strategies/factory.sh"

usage() {
    cat <<EOF
Usage: dbx-smith-spin [options] [strategy] [name] [image] [alias] [bindkey]

Strategies:
  standard            Frictionless, host-mirrored daily driver environment.
  airgapped           Zero-network vault with an isolated, private home directory.
  ghost               Identity obfuscation running as a transient user ('ghostuser').
  isolated-net        Secure sandbox with a dedicated, host-blind NAT bridge network.
  ghost-airgapped     Combined: Transient 'ghostuser' identity with zero network.
  ghost-isolated-net  Combined: Transient 'ghostuser' identity with NAT bridge network.
EOF
}

main() {
    trap 'echo -e "\nCreation interrupted."; exit 130' INT TERM

    case "${1:-}" in
        -h|--help) usage; exit 0 ;;
        -v|--version) echo "dbx-smith-spin v$VERSION"; exit 0 ;;
    esac

    bootstrap

    local strategy_name name image usr_alias usr_bind
    if [[ $# -eq 0 ]]; then
        while [[ -z "${strategy_name:-}" ]]; do read -r -p "Strategy: " strategy_name || exit 130; done
        while [[ -z "${name:-}" ]]; do read -r -p "Box Name: " name || exit 130; done
        while [[ -z "${image:-}" ]]; do read -r -p "Image: " image || exit 130; done
        read -r -p "Alias (optional): " usr_alias || exit 130
        read -r -p "Bindkey (optional, e.g. ^G): " usr_bind || exit 130
    else
        strategy_name="$1"
        name="${2:-}"
        image="${3:-}"
        usr_alias="${4:-}"
        usr_bind="${5:-}"
    fi

    if [[ -z "$name" || -z "$image" || -z "$strategy_name" ]]; then
        echo "Error: Missing required arguments." >&2
        usage >&2; exit 1
    fi

    if distrobox list --no-color | awk -v n="$name" 'NR>1 && $3==n {found=1} END {exit !found}'; then
        echo "Error: Distrobox '$name' already exists." >&2; exit 1
    fi

    # 1. Distro Configuration Injection
    distro_factory "$image"

    # 2. Strategy Loading
    strategy_factory "$strategy_name"

    # 3. Payload Generation
    local color payload
    color=$(get_color "$image")
    payload=$(generate_init_payload "$name" "$color")

    # 4. Provisioning Execution
    echo "Creating distrobox '$name' ($image) using strategy '$strategy_name'..."
    
    # Global array to hold flags (pattern for Bash "objects")
    DBX_FLAGS=()
    
    # Call the strategy-specific flag generator
    local func_name="strategy_${strategy_name//-/_}_get_flags"
    "$func_name" "$name" "$image" "$payload"
    
    # Execute distrobox create
    distrobox create --yes "${DBX_FLAGS[@]}" | sed "s/distrobox enter/dbx-smith/g"

    # 5. Finalization
    local fin_name="strategy_${strategy_name//-/_}_finalize"
    "$fin_name" "$name" "$strategy_name" "$image" "$usr_alias" "$usr_bind"

    echo -e "\n\033[1;32m✔ Successfully provisioned '$name'.\033[0m"
    echo -e "To enter your new sandbox, run:\n\n    \033[1;36mdbx-smith $name\033[0m\n"
}

main "$@"
