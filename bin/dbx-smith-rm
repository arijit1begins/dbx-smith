#!/usr/bin/env bash
# dbx-smith-rm - The Atomic Destructor / DbxSmith
# Refactored for consistency with modular architecture.

set -euo pipefail

# --- [ Dependency Injection & Module Loading ] ---
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dbx-smith"
SRC_DIR="$CONFIG_DIR/src"

# Developer override: if running from a local clone, prioritize the local src/
REPO_SRC="$(dirname "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")")/src"
if [[ -d "$REPO_SRC" ]]; then
    SRC_DIR="$REPO_SRC"
fi
readonly SRC_DIR

# shellcheck source=src/core/constants.sh
# shellcheck disable=SC1091
source "${SRC_DIR}/core/constants.sh"

usage() {
    echo "Usage: dbx-smith-rm [options] <box_name> [box_name_2 ...]"
    echo "An atomic destructor for Distrobox containers and associated infrastructure."
    echo ""
    echo "Options:"
    echo "  -h, --help    Show this help message"
    echo "  -p, --purge   Deep clean: Purge container, isolated home dir, registry manifest,"
    echo "                shortcut fragments, isolated network bridges, and internal Podman volumes."
    echo ""
    echo "For more detailed information and examples, refer to the manual:"
    echo "  man dbx-smith-rm"
}

main() {
    trap 'echo "Teardown interrupted."; exit 1' INT TERM
    trap 'echo "Error encountered during teardown."; exit 1' ERR

    local purge_volume=0
    local targets=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                usage
                exit 0
                ;;
            -p|--purge)
                purge_volume=1
                shift
                ;;
            -*)
                echo "Unknown option: $1" >&2
                usage >&2
                exit 1
                ;;
            *)
                targets+=("$1")
                shift
                ;;
        esac
    done

    if [[ ${#targets[@]} -eq 0 ]]; then
        usage >&2
        exit 1
    fi

    for target in "${targets[@]}"; do
        echo "========================================"
        echo "Tearing down '$target'..."
        # Exact match validation using default whitespace tokenization
        if distrobox list --no-color | awk -v t="$target" 'NR>1 && $3==t {found=1} END {exit !found}'; then
            echo "Stopping distrobox '$target'..."
            distrobox stop "$target" --yes 2>/dev/null || true
            echo "Removing distrobox '$target'..."
            distrobox rm "$target" --yes
        else
            echo "Distrobox '$target' not found or not created by distrobox."
        fi

        # Cleanup filesystem
        [[ -d "$HOME_BASE/$target" ]] && rm -rf "${HOME_BASE:?}/${target:?}" && echo "Removed isolated home directory."
        [[ -f "$ALIAS_DIR/${target}.sh" ]] && rm -f "$ALIAS_DIR/${target}.sh" && echo "Removed alias fragment."
        [[ -f "$REG_DIR/${target}.conf" ]] && rm -f "$REG_DIR/${target}.conf" && echo "Removed registry manifest."
        
        # Clean up associated frozen images (for airgapped boxes)
        local freeze_image="dbx-frozen-${target}"
        if podman image exists "$freeze_image" >/dev/null 2>&1; then
            echo "Removing frozen image '$freeze_image'..."
            podman rmi "$freeze_image" >/dev/null 2>&1 || true
        fi

        # Clean up isolated network if it exists
        if podman network inspect "dbx-net-${target}" >/dev/null 2>&1; then
            echo "Removing isolated network bridge..."
            podman network rm "dbx-net-${target}" >/dev/null 2>&1 || true
        fi

        if (( purge_volume )); then
            echo "Purging Podman volume..."
            podman volume rm "${target}_home" 2>/dev/null || true
        fi

        echo "Teardown complete for '$target'."
    done
}

main "$@"
